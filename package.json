{
  "name": "live2d-desktop-companion",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/build.cjs",
    "start": "npm run build && node scripts/run-electron.cjs",
    "dev": "node scripts/dev-watch.cjs",
    "dev:once": "npm run build && node scripts/run-electron.cjs --dev",
    "test": "npm run build && node --test test/*.test.cjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@pixi/unsafe-eval": "^6.5.10",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "description": "A desktop AI companion built with Electron and Live2D Web SDK.",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.celcat.desktopCompanion",
    "productName": "CelCat",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CelCat"
    }
  }
}
