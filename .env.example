VOLCENGINE_REALTIME_ENABLED=true
VOLCENGINE_REALTIME_PROVIDER_MODE=dialogue
VOLCENGINE_REALTIME_ADDRESS=wss://openspeech.bytedance.com
VOLCENGINE_REALTIME_URI=/api/v3/realtime/dialogue
VOLCENGINE_APP_ID=your_app_id
VOLCENGINE_ACCESS_KEY=your_access_key
VOLCENGINE_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_UID=celcat-local
VOLCENGINE_BOT_NAME=豆包
VOLCENGINE_PROTOCOL_APP_KEY=PlgvMymc7f3tQnJ6

# Agentic model configuration.
# For GLM Coding Plan, use the dedicated coding endpoint instead of the generic API endpoint.
AGENT_PROVIDER=glm
AGENT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AGENT_MODEL=glm5
AGENT_API_KEY=your_agent_api_key

# Optional: override the local workspace directory for agent memory and settings.
# CELCAT_WORKSPACE_DIR=C:\path\to\your\agentWorkspace

# Optional: point CelCat at one or more local skill roots, separated by the OS path delimiter.
# CELCAT_SKILL_DIRS=C:\Users\you\.codex\skills;C:\Users\you\.agents\skills

# Optional: provide external MCP servers as JSON or from a JSON file path.
# CELCAT_MCP_SERVERS_JSON={"mcpServers":{"figmaBridge":{"label":"Figma Bridge","command":"npx","args":["figma-mcp"]}}}
# CELCAT_MCP_CONFIG_PATH=./mcpServers.json

# Optional: custom headers JSON if your deployment requires it.
# VOLCENGINE_REALTIME_HEADERS_JSON={"Authorization":"Bearer ..."}

# Migration target: switch to `voiceChat` while replacing the legacy dialogue transport step by step.
# VOLCENGINE_REALTIME_PROVIDER_MODE=voiceChat
# Optional dedicated voiceChat transport overrides. Current implementation already reads these separately
# so the final StartVoiceChat transport can switch over without changing the rest of the app architecture.
# VOLCENGINE_VOICECHAT_ENABLED=true
# VOLCENGINE_VOICECHAT_ADDRESS=wss://openspeech.bytedance.com
# VOLCENGINE_VOICECHAT_URI=/api/v3/realtime/dialogue
# VOLCENGINE_VOICECHAT_RESOURCE_ID=volc.speech.dialog
# VOLCENGINE_VOICECHAT_APP_ID=your_app_id
# VOLCENGINE_VOICECHAT_ACCESS_KEY=your_access_key
# VOLCENGINE_VOICECHAT_START_EVENT=StartVoiceChat
